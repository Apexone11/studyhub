# ── DATABASE ────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service.
DATABASE_URL=postgresql://studyhub:choose_a_local_db_password@localhost:5432/studyhub?schema=public

# ── AUTH ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_byte_random_hex_string

# ── SERVER ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ────────────────────────────────────────────────────────
# Set these to your production frontend domains after deploy
FRONTEND_URL=https://your-frontend.up.railway.app
FRONTEND_URL_ALT=https://your-frontend-alt.up.railway.app

# ── EMAIL (Gmail SMTP for 2FA and password reset) ───────────────
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── OPTIONAL MONITORING ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── OPTIONAL ADMIN BOOTSTRAP ────────────────────────────────────
# Used only by: npm run seed:admin
ADMIN_USERNAME=
ADMIN_PASSWORD=
