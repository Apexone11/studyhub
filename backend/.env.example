# ── DATABASE ────────────────────────────────────────────────────
# Local/default direct PostgreSQL connection string.
DATABASE_URL=postgresql://studyhub:choose_a_local_db_password@localhost:5432/studyhub?schema=public
# Optional shadow database for prisma migrate dev in local environments.
SHADOW_DATABASE_URL=postgresql://studyhub:choose_a_local_db_password@localhost:5432/studyhub_shadow?schema=public

# ── AUTH ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_byte_random_hex_string

# ── SERVER ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Optional explicit backend origin for HTML sheet preview iframe URLs.
# Set this in production when custom domains sit in front of Railway.
HTML_PREVIEW_ORIGIN=https://api.getstudyhub.org

# ── FILE STORAGE ────────────────────────────────────────────────
# Required in production unless you intentionally allow ephemeral files.
# On Railway, mount a Volume at /data and point uploads there.
UPLOADS_DIR=/data/uploads
# Local/test only:
# ALLOW_EPHEMERAL_UPLOADS=true

# ── CORS ────────────────────────────────────────────────────────
# Set these to your production frontend domains after deploy
FRONTEND_URL=https://your-frontend.up.railway.app
FRONTEND_URL_ALT=https://your-frontend-alt.up.railway.app

# ── EMAIL (used for verification, reset, 2FA, and admin notifications) ──
# Recommended production mode (Resend API):
EMAIL_TRANSPORT=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=StudyHub <no-reply@getstudyhub.org>
# Optional if you need a non-default API endpoint:
# RESEND_API_BASE_URL=https://api.resend.com
# Webhook verification for delivery event ingestion:
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret
RESEND_WEBHOOK_STRICT=true

# SMTP fallback mode (set EMAIL_TRANSPORT to smtp-host/provider or leave unset):
# EMAIL_USER=abdulrfornah@getstudyhub.org
# EMAIL_PASS=your-email-app-password
# EMAIL_SERVICE=gmail
# Optional custom SMTP host instead of EMAIL_SERVICE:
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=false

# Optional local/test transport:
# EMAIL_TRANSPORT=json
# EMAIL_CAPTURE_DIR=./tmp/email-capture

# ── OPTIONAL MONITORING ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── OPTIONAL ADMIN BOOTSTRAP ────────────────────────────────────
# Used only by: npm run seed:admin
ADMIN_EMAIL=abdulrfornah@getstudyhub.org
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── OPTIONAL CONTENT MODERATION (text only) ─────────────────────
# Used by backend/src/lib/moderation/moderationEngine.js (text scoring).
# Distinct from ANTHROPIC_API_KEY (Hub AI).
OPENAI_API_KEY=

# ── ANTHROPIC (Hub AI) ──────────────────────────────────────────
# Required for /api/ai endpoints. Note: backend uses ANTHROPIC_API_KEY,
# NOT OPENAI_API_KEY (that var is the moderation engine only).
ANTHROPIC_API_KEY=

# ── GOOGLE OAUTH ────────────────────────────────────────────────
# Required for Google sign-in. Frontend uses VITE_GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_SECRET is server-side only — used to verify Google ID
# tokens server-to-server in auth.google.controller.js.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── PROVENANCE / AUDIT-GRADE SHEETS ─────────────────────────────
# 32-byte hex key (64 hex chars). Encrypts provenance manifests
# attached to creator-audit-grade sheets. REQUIRED IN PRODUCTION —
# backend/src/lib/provenance.js refuses to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVENANCE_SECRET=

# ── R2 OBJECT STORAGE (Cloudflare) ──────────────────────────────
# Required for video uploads, sheet/note attachments, avatars, and
# public asset hosting. Backend reads these in lib/r2Storage.js.
# R2_PUBLIC_URL is the customer-facing CDN URL prefix (e.g.
# https://cdn.getstudyhub.org). When unset the backend proxies
# media through /api/video/media/:key (slower, fine for dev).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── WEBAUTHN (optional second factor) ───────────────────────────
# RP ID is the apex domain (no scheme). ORIGIN includes the scheme
# and must match the frontend origin exactly.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# ── STRIPE PRICE IDs ────────────────────────────────────────────
# Looked up via planFromPriceId() in payments.constants.js. Donations
# use price_data with a custom amount, not a fixed price ID.
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_DONATION=

# ── GOOGLE BOOKS ────────────────────────────────────────────────
# Optional. Library page falls back to anonymous quota when unset.
GOOGLE_BOOKS_API_KEY=

# ── TENOR (GIF picker) ──────────────────────────────────────────
# Optional. Server-side Tenor API key for the /api/gifs proxy.
# When unset the GIF picker returns 503 and the UI shows
# "GIF search is unavailable" — never breaks the app.
# Get a key from https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=

# ── CSP REPORTING ───────────────────────────────────────────────
# Optional Sentry CSP intake URL. When set, helmet emits a
# `report-uri` directive so violation reports flow into Sentry.
CSP_REPORT_URI=

# ── ABUSE DETECTION (optional) ──────────────────────────────────
# Used by backend/src/lib/abuseDetection.js. Leave disabled in dev.
ABUSE_DETECTION_ENABLED=false
ABUSE_RATE_WINDOW_MS=60000
ABUSE_RATE_THRESHOLD=20
ABUSE_DUPLICATE_WINDOW_HOURS=24
ABUSE_NEW_ACCOUNT_HOURS=72

# ── CLAMAV (optional) ───────────────────────────────────────────
# Antivirus scanning for uploaded files. Disabled by default in dev.
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
CLAMAV_DISABLED=true

# ── EMAIL STARTUP MODE ──────────────────────────────────────────
# When true, backend refuses to start if email transport is misconfigured.
EMAIL_STARTUP_STRICT=false

# ── ROLES V2 FLAG SEED ──────────────────────────────────────────
# scripts/seedRolesV2Flags.js force-enables `flag_roles_v2_oauth_picker`
# on every boot so an accidental admin-UI flip-off self-heals on the
# next deploy. Set this to `true` to opt out (kill-switching via admin
# UI wins for that boot — useful for incident response without a code
# change). Leave unset for the default force-on behavior.
ROLES_V2_HONOR_ADMIN_TOGGLES=

# ── POSTHOG (optional product analytics, server-side) ───────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── GEOIP (optional) ────────────────────────────────────────────
# Directory containing MaxMind GeoLite2 .mmdb files. If missing, geo
# lookup no-ops and risk scoring skips geo-based signals.
GEOIP_DB_DIR=/data/geoip
# Free license key from https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# ── INACTIVE SESSION SWEEP ──────────────────────────────────────
# Tunes the in-process daily sweep that revokes sessions idle for
# INACTIVE_SESSION_DAYS. Default 24h interval / 30 days.
#
# ENABLE_INACTIVE_SESSION_SWEEP gating (off by default in EVERY env):
#   - Unset / empty  → sweep is OFF in prod, staging, test, local dev.
#   - Set to "true" or "1"   → sweep runs on this instance.
#   - Anything else (including "false", "0") → sweep stays OFF.
# Off-by-default is the safe choice because any horizontally-scaled
# deployment (prod OR staging) that defaults-on would have every
# replica firing the same idempotent sweep, multiplying DB load. Pick
# exactly ONE worker per environment and set ENABLE=true on that one.
# For dev: set it in .env.local if you want to exercise the sweep.
INACTIVE_SESSION_SWEEP_INTERVAL_MS=86400000
INACTIVE_SESSION_DAYS=30
# ENABLE_INACTIVE_SESSION_SWEEP=true

# ── ORPHAN VIDEO SWEEPER ──────────────────────────────────────
# Reclaims R2 bytes from abandoned video uploads:
#   1. Failed/stalled processing rows older than 6h that are not
#      referenced by any FeedPost or AnnouncementMedia (and have no
#      pending VideoAppeal).
#   2. Ready videos older than 24h that the user never attached to
#      a post or announcement.
#
# SWEEP_ORPHAN_VIDEOS_ON_START gating (off by default in EVERY env):
#   - Unset / empty               -> sweep is OFF.
#   - Set to "true" or "1"        -> sweep runs on this instance.
#   - Anything else               -> sweep stays OFF.
# Off-by-default mirrors ENABLE_INACTIVE_SESSION_SWEEP -- flip it on
# for exactly ONE worker in any horizontally-scaled deployment so two
# replicas do not race to delete the same R2 objects.
# SWEEP_ORPHAN_VIDEOS_ON_START=true

# ── FIELD ENCRYPTION (PII vault) ────────────────────────────────
# Required per railway-deployment-guide-v2.0. Rotation requires adding
# FIELD_ENCRYPTION_KEY_PREV in parallel before changing the main key.
FIELD_ENCRYPTION_KEY=
# FIELD_ENCRYPTION_KEY_PREV=

# ── CREATOR AUDIT ───────────────────────────────────────────────
# The Creator Audit backend foundation currently has no dedicated secrets.
# It uses the app's normal database, CSRF/origin checks, Sentry, and centralized
# rate limiters. Document any future audit-specific webhook or AI keys here.

# ── OPTIONAL AWS KMS PROFILE PII VAULT ──────────────────────────
# Required if you want encrypted age/location editing to work.
# The app stores sensitive profile fields through the PII vault and
# expects a real AWS KMS key ARN plus AWS credentials in the runtime env.
# Example ARN format:
# KMS_KEY_ARN=arn:aws:kms:us-east-2:123456789012:key/your-key-id
KMS_KEY_ARN=
# Defaults to us-east-2 in code if omitted.
AWS_REGION=us-east-2
# Optional local admin diagnostics endpoint for KMS status.
ENABLE_KMS_STATUS=false

# ── OPTIONAL LOCAL BETA USERS ───────────────────────────────────
# Used only by: npm run seed:beta
BETA_OWNER_USERNAME=studyhub_owner
BETA_OWNER_PASSWORD=AdminPass123
BETA_ADMIN_USERNAME=beta_admin
BETA_ADMIN_PASSWORD=BetaAdmin123!
BETA_STUDENT1_USERNAME=beta_student1
BETA_STUDENT1_PASSWORD=BetaStudent123!
BETA_STUDENT2_USERNAME=beta_student2
BETA_STUDENT2_PASSWORD=BetaStudent123!

# ── INFRASTRUCTURE OVERRIDES (optional) ─────────────────────────
# Default-safe paths; override only on multi-disk or networked-storage hosts.
STUDYHUB_RUNTIME_DIR=
STUDYHUB_HTML_UPLOADS=
STUDYHUB_ASSET_CDN=

# ── LEGAL CONTACT (optional) ────────────────────────────────────
# Address that DSAR / takedown / legal-acceptance emails are routed to.
# Defaults to abdulrfornah@gmail.com when unset.
LEGAL_CONTACT_EMAIL=

# ── HTML PREVIEW TOKEN TTL (optional) ───────────────────────────
# Sandbox preview tokens expire this many seconds after issue. Default 300.
HTML_PREVIEW_TOKEN_TTL_SECONDS=300

# ── HTML ARCHIVE SCHEDULER (optional) ───────────────────────────
# Background job that archives old quarantined HTML out of hot storage.
HTML_ARCHIVE_BATCH_SIZE=100
HTML_ARCHIVE_DAYS=180
HTML_ARCHIVE_INTERVAL_MS=86400000

# ── MODERATION CLEANUP SCHEDULER (optional) ─────────────────────
# Background job that purges expired strikes / closed cases past retention.
MODERATION_CLEANUP_DRY_RUN=false
MODERATION_CLEANUP_INTERVAL_MS=86400000
MODERATION_GRACE_DAYS=30

# ── AI REVIEWER KILL SWITCH (optional) ──────────────────────────
# When false, sheetReviewer.service skips the AI review and the workflow
# falls back to "tier 2 = pending_review for admin queue" only.
AI_REVIEW_ENABLED=true

# ── DEBUG (optional, dev only) ──────────────────────────────────
# DEBUG_LOG=true enables verbose pretty-print logging in development.
# ENABLE_QUERY_LOGGING=true logs every Prisma query (very chatty).
DEBUG_LOG=
ENABLE_QUERY_LOGGING=

# ── EMAIL TRANSPORT LEGACY ALIAS (optional) ─────────────────────
# Older code paths read EMAIL_PROVIDER; new code reads EMAIL_TRANSPORT.
# Set whichever your deployment scripts use; the other is ignored.
EMAIL_PROVIDER=
