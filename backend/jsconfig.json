{
  "compilerOptions": {
    "checkJs": false,
    "strict": false,
    "module": "commonjs",
    "target": "ES2022",
    "moduleResolution": "node16",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@middleware/*": ["src/middleware/*"],
      "@modules/*": ["src/modules/*"]
    },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "prisma"]
}
