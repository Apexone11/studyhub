// ── Library Catalog Cache ────────────────────────────────────

// Phase 4: Plagiarism detection — per-sheet report when similarity is found.
// Each report links a sheet to one or more matched sheets, stores the
// similarity score, match type, AI verdict, and user dispute status.
model PlagiarismReport {
  id                  Int       @id @default(autoincrement())
  sheetId             Int
  matchedSheetId      Int
  similarityScore     Float
  matchType           String    @default("simhash") // "exact" | "simhash" | "ai" | "ngram"
  highlightedSections Json? // JSON array of matched ranges
  aiVerdict           String? // AI-generated verdict text
  aiConfidence        Float? // 0-1
  status              String    @default("pending") // "pending" | "confirmed" | "dismissed" | "disputed"
  resolvedAt          DateTime?
  resolvedById        Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sheet        StudySheet          @relation("PlagiarismReportSheet", fields: [sheetId], references: [id], onDelete: Cascade)
  matchedSheet StudySheet          @relation("PlagiarismReportMatched", fields: [matchedSheetId], references: [id], onDelete: Cascade)
  resolvedBy   User?               @relation("PlagiarismReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  disputes     PlagiarismDispute[]

  @@unique([sheetId, matchedSheetId])
  @@index([sheetId, status])
  @@index([matchedSheetId])
  @@index([status, createdAt])
}

model PlagiarismDispute {
  id         Int       @id @default(autoincrement())
  reportId   Int
  userId     Int
  reason     String    @db.Text
  status     String    @default("pending") // "pending" | "accepted" | "rejected"
  reviewedBy Int?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  report   PlagiarismReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user     User             @relation("PlagiarismDisputeFiler", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?            @relation("PlagiarismDisputeReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([reportId, userId])
  @@index([reportId, status])
}

model CachedBook {
  id            Int      @id @default(autoincrement())
  volumeId      String   @unique
  title         String
  authors       Json     @default("[]")
  categories    Json     @default("[]")
  language      String   @default("en")
  pageCount     Int      @default(0)
  coverUrl      String?
  previewLink   String?
  description   String?
  publishedDate String?
  syncedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pageCount(sort: Desc)])
  @@index([language])
}

// ═══════════════════════════════════════════════════════════════════════════
// Video — Upload, transcode, and stream user videos (feed posts, announcements)
// ═══════════════════════════════════════════════════════════════════════════

model Video {
  id                 Int      @id @default(autoincrement())
  userId             Int
  title              String?
  description        String?
  r2Key              String   @unique
  status             String   @default("processing") // processing, ready, failed
  duration           Float?
  width              Int?
  height             Int?
  fileSize           Int?
  mimeType           String?
  thumbnailR2Key     String?
  variants           Json? // { "360p": { key, width, height }, "720p": {...}, "1080p": {...} }
  hlsManifestR2Key   String?
  processingStep     String? // Current step: downloading, analyzing, thumbnail, transcoding, finalizing
  processingProgress Int? // 0-100 percentage
  downloadable       Boolean  @default(true) // Whether viewers can download this video
  contentHash        String?
  watermarkPosition  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user              User                @relation("UserVideos", fields: [userId], references: [id], onDelete: Cascade)
  captions          VideoCaption[]
  feedPosts         FeedPost[]          @relation("FeedPostVideo")
  announcementMedia AnnouncementMedia[]
  appeals           VideoAppeal[]       @relation("VideoAppealVideo")
  appealOriginals   VideoAppeal[]       @relation("VideoAppealOriginal")

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([contentHash])
}

model VideoCaption {
  id        Int      @id @default(autoincrement())
  videoId   Int
  language  String   @db.VarChar(10)
  label     String
  vttR2Key  String
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, language])
  @@index([videoId])
}

model VideoAppeal {
  id              Int      @id @default(autoincrement())
  videoId         Int
  uploaderId      Int
  originalVideoId Int
  status          String   @default("pending")
  reason          String?
  reviewedBy      Int?
  reviewNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  video         Video @relation("VideoAppealVideo", fields: [videoId], references: [id], onDelete: Cascade)
  uploader      User  @relation("VideoAppealUploader", fields: [uploaderId], references: [id])
  originalVideo Video @relation("VideoAppealOriginal", fields: [originalVideoId], references: [id])
  reviewer      User? @relation("VideoAppealReviewer", fields: [reviewedBy], references: [id])

  @@index([videoId])
  @@index([uploaderId])
  @@index([status])
}

model AnnouncementMedia {
  id             Int      @id @default(autoincrement())
  announcementId Int
  type           String // "image" or "video"
  url            String
  position       Int      @default(0)
  videoId        Int?
  fileName       String?
  fileSize       Int?
  width          Int?
  height         Int?
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  video        Video?       @relation(fields: [videoId], references: [id], onDelete: SetNull)

  @@index([announcementId, position])
}

// ═══════════════════════════════════════════════════════════════════════════
// Analytics — Track page views and user activity for admin dashboard
// ═══════════════════════════════════════════════════════════════════════════

model PageView {
  id        Int      @id @default(autoincrement())
  userId    Int?
  path      String
  country   String?  @db.VarChar(2)
  device    String?  @db.VarChar(20)
  browser   String?  @db.VarChar(50)
  os        String?  @db.VarChar(50)
  sessionId String?  @db.VarChar(64)
  duration  Int      @default(0)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

