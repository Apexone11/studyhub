  @@unique([shelfId, volumeId])
  @@index([shelfId])
}

model ReadingProgress {
  id         Int      @id @default(autoincrement())
  userId     Int
  volumeId   String
  cfi        String?
  percentage Float    @default(0)
  lastReadAt DateTime @default(now())
