  userId    Int
  reason    String
  caseId    Int?
  issuedAt  DateTime        @default(now())
  expiresAt DateTime
  decayedAt DateTime?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  case      ModerationCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId, decayedAt, expiresAt])
}

model Appeal {
