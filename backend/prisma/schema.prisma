  category         String?
  provider         String?
  evidence         Json?
  reviewedBy       Int?
  reviewNote       String?
  source           String               @default("auto")
  reporterUserId   Int?
  reasonCategory   String?
  excerpt          String?
  claimedByAdminId Int?
  claimedAt        DateTime?
  contentPurged    Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User?                @relation("ModerationCaseAuthor", fields: [userId], references: [id], onDelete: SetNull)
  reviewer         User?                @relation("ModerationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reporter         User?                @relation("ModerationReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  claimedBy        User?                @relation("ModerationClaimer", fields: [claimedByAdminId], references: [id], onDelete: SetNull)
