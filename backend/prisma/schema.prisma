model SubscriptionPause {
  id        Int       @id @default(autoincrement())
  userId    Int
  reason    String?
  pausedAt  DateTime  @default(now())
  resumeAt  DateTime
  resumedAt DateTime?
  status    String    @default("active") // "active", "resumed", "expired"
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════
// User Reviews — Public testimonials shown on homepage
// ═══════════════════════════════════════════════════════════════════════════

model UserReview {
  id               Int      @id @default(autoincrement())
  userId           Int
  stars            Int // 1-5
  text             String   @db.VarChar(500)
  status           String   @default("pending") // "pending", "approved", "rejected"
  aiClassification String? // "positive", "negative", "neutral"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId]) // one review per user
  @@index([status, stars])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// Review Reports — AI-generated weekly analysis of user reviews
// ═══════════════════════════════════════════════════════════════════════════

model ReviewReport {
  id           Int      @id @default(autoincrement())
  periodStart  DateTime // start of the review period
  periodEnd    DateTime // end of the review period
  reviewCount  Int // number of reviews analyzed
  averageStars Float // average star rating in the period
  strengths    String   @db.Text // AI-identified strengths (JSON array)
  weaknesses   String   @db.Text // AI-identified weaknesses (JSON array)
  improvements String   @db.Text // AI-suggested actionable improvements (JSON array)
  rawAnalysis  String   @db.Text // full AI analysis text
  generatedBy  Int? // admin user who triggered generation
  createdAt    DateTime @default(now())

  generatedByUser User? @relation("ReviewReportGenerator", fields: [generatedBy], references: [id], onDelete: SetNull)

  @@index([periodEnd])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// AI Review Log — Audit trail for AI-powered sheet reviews
// ═══════════════════════════════════════════════════════════════════════════

model AiReviewLog {
  id         String   @id @default(cuid())
  sheetId    Int
  decision   String // "approve", "reject", "escalate"
  confidence Int // 0-100
  riskScore  Int // 0-100
  findings   String   @db.Text // JSON array of findings
  reasoning  String   @db.Text
  model      String // which Claude model was used
  inputTier  Int // what tier the scanner assigned (1 or 2)
  createdAt  DateTime @default(now())

  sheet StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId])
  @@index([decision])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// Session — Server-side session tracking for per-device JWT management
// ═══════════════════════════════════════════════════════════════════════════

model Session {
  id              String    @id @default(cuid())
  userId          Int
  jti             String    @unique
  userAgent       String?   @db.VarChar(512)
  ipAddress       String?   @db.VarChar(45)
  deviceLabel     String?   @db.VarChar(100)
  deviceKind      String?   @db.VarChar(16)
  country         String?   @db.VarChar(2)
  region          String?   @db.VarChar(10)
  city            String?   @db.VarChar(128)
  riskScore       Int?
  trustedDeviceId String?
  lastActiveAt    DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedDevice TrustedDevice? @relation(fields: [trustedDeviceId], references: [id])

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
  @@index([trustedDeviceId])
}

// ═══════════════════════════════════════════════════════════════════════════
// LoginChallenge — Pending email-code step-up challenge.
// Created when a login lands in the "challenge" risk band (score >= 60).
// ═══════════════════════════════════════════════════════════════════════════

model LoginChallenge {
  id              String    @id @default(cuid())
  userId          Int
  pendingDeviceId String
  codeHash        String    @db.VarChar(128)
  attempts        Int       @default(0)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  ipAddress       String?   @db.VarChar(45)
  userAgent       String?   @db.VarChar(512)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// TrustedDevice — Stable device identity across sessions
// Keyed by the httpOnly `sh_did` cookie. Survives logout so we can recognize
// a returning device. Revoked devices are treated as new on next login.
// ═══════════════════════════════════════════════════════════════════════════

model TrustedDevice {
  id          String    @id @default(cuid())
  userId      Int
  deviceId    String
  label       String
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  lastIp      String?   @db.VarChar(45)
  lastCountry String?   @db.VarChar(2)
  lastRegion  String?   @db.VarChar(10)
  trustedAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([userId, deviceId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// SecurityEvent — Audit log for security-relevant actions (login, logout, etc.)
// ═══════════════════════════════════════════════════════════════════════════

model SecurityEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventType String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// StudyStatus — Per-user study tracking state for sheets (synced across devices)
// ═══════════════════════════════════════════════════════════════════════════

model StudyStatus {
  userId    Int
  sheetId   Int
  status    String
  updatedAt DateTime @default(now()) @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
  @@index([userId, status])
  @@index([sheetId])
}

// ═══════════════════════════════════════════════════════════════════════════
// RequestMetric — Per-request latency data for observability dashboard
// ═══════════════════════════════════════════════════════════════════════════

model RequestMetric {
  id         Int      @id @default(autoincrement())
  method     String
  routeGroup String
  route      String
  statusCode Int
  durationMs Int
  userId     Int?
  createdAt  DateTime @default(now())

  @@index([routeGroup, createdAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// OnboardingProgress — First-run onboarding state per user
// ═══════════════════════════════════════════════════════════════════════════

model OnboardingProgress {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  currentStep     Int       @default(1)
  schoolSelected  Boolean   @default(false)
  coursesAdded    Int       @default(0)
  firstActionType String?
  invitesSent     Int       @default(0)
  completedAt     DateTime?
  skippedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([completedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// Referral — Peer-to-peer invite tracking for growth loop
// ═══════════════════════════════════════════════════════════════════════════

model Referral {
  id            Int       @id @default(autoincrement())
  inviterId     Int
  code          String
  email         String?
  channel       String
  invitedUserId Int?
  sentAt        DateTime  @default(now())
  acceptedAt    DateTime?
  rewardGranted Boolean   @default(false)

  inviter     User  @relation("InvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitedUser User? @relation("InvitedByReferral", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([inviterId])
  @@index([email])
  @@index([code])
  @@index([acceptedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// ReferralReward — Milestone-based reward ledger
// ═══════════════════════════════════════════════════════════════════════════

model ReferralReward {
  id        Int      @id @default(autoincrement())
  userId    Int
  milestone Int
  proMonths Int
  badgeKey  String?
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
}

model RoleChangeLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  fromAccountType String
  toAccountType   String
  reason          String?  @db.VarChar(500)
  wasRevert       Boolean  @default(false)
  ip              String?
  userAgent       String?
  changedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, changedAt])
  @@index([changedAt])
}

model UserEnrollmentArchive {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int
  archivedAt DateTime @default(now())
  reason     String   @default("role_change")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, archivedAt])
}

model Hashtag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  follows HashtagFollow[]

  @@index([name])
}

model HashtagFollow {
  id        Int      @id @default(autoincrement())
  userId    Int
  hashtagId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([userId, hashtagId])
  @@index([userId])
  @@index([hashtagId])
}

model LearningGoal {
  id        Int      @id @default(autoincrement())
  userId    Int
  goal      String   @db.VarChar(500)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// Phase 2 of v2 design refresh — Upcoming Exams.
// See docs/internal/design-refresh-v2-master-plan.md §5.
// Private by default; future "course"-level visibility is a stretch item, not in Phase 2.
model CourseExam {
  id                  Int      @id @default(autoincrement())
  userId              Int
  courseId            Int
  title               String   @db.VarChar(120)
  location            String?  @db.VarChar(120)
  examDate            DateTime
  visibility          String   @default("private")
  notes               String?  @db.VarChar(500)
  // 0-100 progress bar shown on the UpcomingExamsCard. DB-side
  // CHECK constraint (see migration 20260424110200_add_preparedness_
  // to_course_exam) pins the range so the frontend never has to
  // clamp. Default 0 = "new exam, no studying yet."
  preparednessPercent Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, examDate])
  @@index([courseId, examDate])
}

// Section — teacher-owned cohort used for section-aware publishing.
// Week 3 of Design Refresh v2 (see docs/internal/design-refresh-v2-
// week2-to-week5-execution.md). A section is optionally tied to a
// Course; a teacher can also create ad-hoc sections that span courses.
// joinCode is what students enter to self-enroll from
// /classes/join?code=XYZ.
model Section {
  id          Int      @id @default(autoincrement())
  courseId    Int?
  teacherId   Int
  name        String
  description String   @default("")
  joinCode    String   @unique
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course?              @relation(fields: [courseId], references: [id], onDelete: SetNull)
  teacher     User                 @relation("SectionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments SectionEnrollment[]
  assignments MaterialAssignment[]

  @@index([teacherId, archived])
  @@index([courseId])
}

// SectionEnrollment — a student's membership in a Section. Role is a
// String so future "ta" (teaching assistant) roles can be added without
// a schema migration.
model SectionEnrollment {
  id         Int      @id @default(autoincrement())
  sectionId  Int
  userId     Int
  role       String   @default("student")
  enrolledAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user    User    @relation("SectionEnrollmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectionId, userId])
  @@index([userId])
}

// Material — teacher-curated wrapper around an existing StudySheet or
// Note. The wrapper exists so teachers can override the title, attach
// per-class instructions, and group items by week without mutating the
// underlying content. Exactly one of (sheetId, noteId) is expected to
// be non-null; this invariant is enforced in the service layer because
// Postgres CHECK constraints aren't first-class in Prisma.
model Material {
  id           Int      @id @default(autoincrement())
  teacherId    Int
  sheetId      Int?
  noteId       Int?
  title        String
  instructions String   @default("")
  week         Int?
  archived     Boolean  @default(false)
  lastAuditGrade  String?   @db.VarChar(1)
  lastAuditReport Json?
  lastAuditedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher     User                 @relation("MaterialTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  sheet       StudySheet?          @relation("MaterialSheet", fields: [sheetId], references: [id], onDelete: SetNull)
  note        Note?                @relation("MaterialNote", fields: [noteId], references: [id], onDelete: SetNull)
  assignments MaterialAssignment[]

  @@index([teacherId, archived])
  @@index([sheetId])
  @@index([noteId])
}

// MaterialAssignment — join between Material and Section with per-
// assignment metadata (optional due date). Unique on (materialId,
// sectionId) so the same material cannot be assigned to the same
// section twice.
model MaterialAssignment {
  id         Int       @id @default(autoincrement())
  materialId Int
  sectionId  Int
  dueAt      DateTime?
  assignedAt DateTime  @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([materialId, sectionId])
  @@index([sectionId, dueAt])
}
