generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      Int       @id @default(autoincrement())
  username                String    @unique
  passwordHash            String
  role                    String    @default("student")
  trustLevel              String    @default("new")
  trustedAt               DateTime?
  email                   String?   @unique
  emailHash               String?
  emailVerified           Boolean   @default(false)
  isStaffVerified         Boolean   @default(false)
  emailVerificationCode   String?
  emailVerificationExpiry DateTime?
  failedAttempts          Int       @default(0)
  lockedUntil             DateTime?
  lastFailedLoginAt       DateTime?
  displayName             String?
  bio                     String?   @db.VarChar(500)
  avatarUrl               String?
  coverImageUrl           String?
  profileLinks            Json      @default("[]")
  twoFaEnabled            Boolean   @default(false)
  twoFaCode               String?
  twoFaExpiry             DateTime?
  googleId                String?   @unique
  authProvider            String    @default("local")
  accountType             String    @default("student")
  pendingAccountType      String?
  accountTypeChangedAt    DateTime?
  previousAccountType     String?
  roleRevertDeadline      DateTime?
  learningGoal            String?   @db.VarChar(500)
  termsAcceptedVersion    String?
  termsAcceptedAt         DateTime?
  isPrivate               Boolean   @default(false)
  createdAt               DateTime  @default(now())

  studySheets                StudySheet[]
  enrollments                Enrollment[]
  schoolEnrollments          UserSchoolEnrollment[]
  comments                   Comment[]
  starredSheets              StarredSheet[]
  passwordResetToken         PasswordResetToken?
  announcements              Announcement[]
  notes                      Note[]
  noteComments               NoteComment[]
  noteStars                  NoteStar[]
  noteVersions               NoteVersion[]
  reactions                  Reaction[]
  feedPosts                  FeedPost[]
  feedPostComments           FeedPostComment[]
  feedPostReactions          FeedPostReaction[]
  proposedContributions      SheetContribution[]       @relation("ContributionProposer")
  reviewedContributions      SheetContribution[]       @relation("ContributionReviewer")
  contributionComments       ContributionComment[]     @relation("ContributionCommentAuthor")
  verificationChallenges     VerificationChallenge[]
  notificationsReceived      Notification[]            @relation("NotifRecipient")
  notificationsSent          Notification[]            @relation("NotifActor")
  following                  UserFollow[]              @relation("Following")
  followers                  UserFollow[]              @relation("Followers")
  htmlVersions               SheetHtmlVersion[]
  suppressionAuditsPerformed EmailSuppressionAudit[]   @relation("EmailSuppressionAuditActor")
  preferences                UserPreferences?
  strikes                    Strike[]
  appeals                    Appeal[]
  restrictions               UserRestriction[]
  moderationCases            ModerationCase[]          @relation("ModerationCaseAuthor")
  moderationReviews          ModerationCase[]          @relation("ModerationReviewer")
  moderationReports          ModerationCase[]          @relation("ModerationReporter")
  moderationClaims           ModerationCase[]          @relation("ModerationClaimer")
  appealReviews              Appeal[]                  @relation("AppealReviewer")
  moderationLogs             ModerationLog[]           @relation("ModerationLogUser")
  sheetCommits               SheetCommit[]
  webauthnCredentials        WebAuthnCredential[]
  reviewedSheets             StudySheet[]              @relation("SheetReviewer")
  pinnedSheets               UserPinnedSheet[]
  dailyActivity              UserDailyActivity[]
  badges                     UserBadge[]
  sensitiveData              UserSensitive?
  blockedUsers               UserBlock[]               @relation("BlockedByUser")
  blockedByUsers             UserBlock[]               @relation("BlockedUser")
  mutedUsers                 UserMute[]                @relation("MutedByUser")
  mutedByUsers               UserMute[]                @relation("MutedUser")
  conversationsCreated       Conversation[]            @relation("ConversationCreator")
  conversationParticipants   ConversationParticipant[]
  messagesSent               Message[]                 @relation("MessageSender")
  messageReactions           MessageReaction[]         @relation("MessageReactionUser")
  messagePollVotes           MessagePollVote[]
  studyGroupsCreated         StudyGroup[]              @relation("StudyGroupCreator")
  studyGroupsDeleted         StudyGroup[]              @relation("StudyGroupDeleter")
  studyGroupMemberships      StudyGroupMember[]
  studyGroupMutesIssued      StudyGroupMember[]        @relation("StudyGroupMemberMutedBy")
  groupMediaUsage            GroupMediaUsage[]
  groupReportsFiled          GroupReport[]             @relation("GroupReportReporter")
  groupReportsResolved       GroupReport[]             @relation("GroupReportResolver")
  groupAppealsFiled          GroupAppeal[]             @relation("GroupAppealAppealer")
  groupAppealsResolved       GroupAppeal[]             @relation("GroupAppealResolver")
  groupAuditActions          GroupAuditLog[]           @relation("GroupAuditActor")
  groupBlocksReceived        GroupBlock[]              @relation("GroupBlockUser")
  groupBlocksIssued          GroupBlock[]              @relation("GroupBlockActor")
  plagiarismReportsResolved  PlagiarismReport[]        @relation("PlagiarismReportResolver")
  plagiarismDisputesFiled    PlagiarismDispute[]       @relation("PlagiarismDisputeFiler")
  plagiarismDisputesReviewed PlagiarismDispute[]       @relation("PlagiarismDisputeReviewer")
  groupResources             GroupResource[]
  groupSessionRsvps          GroupSessionRsvp[]
  groupDiscussionPosts       GroupDiscussionPost[]
  groupDiscussionReplies     GroupDiscussionReply[]
  discussionUpvotes          DiscussionUpvote[]
  shareLinksCreated          ShareLink[]               @relation("ShareLinkCreator")
  contentSharedBy            ContentShare[]            @relation("ContentSharedBy")
  contentSharedWith          ContentShare[]            @relation("ContentSharedWith")
  aiConversations            AiConversation[]
  aiMessages                 AiMessage[]               @relation("AiMessageUser")
  aiUsageLogs                AiUsageLog[]
  aiSuggestions              AiSuggestion[]
  bookShelves                BookShelf[]
  readingProgress            ReadingProgress[]
  bookBookmarks              BookBookmark[]
  videos                     Video[]                   @relation("UserVideos")
  pageViews                  PageView[]
  subscription               Subscription?
  payments                   Payment[]
  donations                  Donation[]
  creatorAuditConsent        CreatorAuditConsent?
  commentReactions           CommentReaction[]
  feedPostCommentReactions   FeedPostCommentReaction[]
  noteCommentReactions       NoteCommentReaction[]
  noteReactions              NoteReaction[]
  legalAcceptances           LegalAcceptance[]
  referralCodes              ReferralCode[]
  referralRedemptions        ReferralRedemption[]
  giftsSent                  GiftSubscription[]        @relation("GiftsSent")
  giftsReceived              GiftSubscription[]        @relation("GiftsReceived")
  subscriptionPauses         SubscriptionPause[]
  lastActiveAt               DateTime?
  userReviews                UserReview[]
  generatedReviewReports     ReviewReport[]            @relation("ReviewReportGenerator")
  videoAppeals               VideoAppeal[]             @relation("VideoAppealUploader")
  videoAppealReviews         VideoAppeal[]             @relation("VideoAppealReviewer")
  sessions                   Session[]
  trustedDevices             TrustedDevice[]
  loginChallenges            LoginChallenge[]
  securityEvents             SecurityEvent[]
  studyStatuses              StudyStatus[]
  onboardingProgress         OnboardingProgress?
  referralCode               String?                   @unique
  referredByUserId           Int?
  proRewardExpiresAt         DateTime?
  referredBy                 User?                     @relation("ReferredBy", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referralsReceived          User[]                    @relation("ReferredBy")
  invitesSent                Referral[]                @relation("InvitesSent")
  invitesReceived            Referral[]                @relation("InvitedByReferral")
  referralRewards            ReferralReward[]
  roleChangeLogs             RoleChangeLog[]
  enrollmentArchives         UserEnrollmentArchive[]
  hashtagFollows             HashtagFollow[]
  learningGoals              LearningGoal[]
  courseExams                CourseExam[]
  sectionsTaught             Section[]                 @relation("SectionTeacher")
  sectionEnrollments         SectionEnrollment[]       @relation("SectionEnrollmentUser")
  materialsAuthored          Material[]                @relation("MaterialTeacher")

  @@index([role])
  @@index([emailHash])
  @@index([lastActiveAt])
}

model CreatorAuditConsent {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  acceptedAt       DateTime  @default(now())
  docVersion       String    @db.VarChar(16)
  ipAddress        String?   @db.VarChar(64)
  userAgent        String?   @db.VarChar(512)
  // Provenance of the row so auditors and legal can tell genuine
  // acceptances from synthetic ones. 'user' = clicked through the
  // modal, 'backfill' = inserted by backfillCreatorConsent.js at
  // ship time, 'seed' = inserted by seedBetaUsers.js for local dev.
  acceptanceMethod String    @default("user") @db.VarChar(16)
  // Soft-delete: revocation sets revokedAt instead of deleting the
  // row, preserving the audit trail for legal disputes. Active
  // consent = revokedAt IS NULL AND docVersion = current.
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model LegalDocument {
  id               Int               @id @default(autoincrement())
  slug             String
  version          String
  title            String
  summary          String            @default("")
  intro            String            @default("")
  updatedLabel     String            @default("")
  bodyText         String            @db.Text
  source           String            @default("database")
  termlyEmbedId    String?
  termlyUrl        String?
  requiredAtSignup Boolean           @default(false)
  isCurrent        Boolean           @default(false)
  publishedAt      DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  acceptances      LegalAcceptance[]

  @@unique([slug, version])
  @@index([slug, isCurrent, publishedAt(sort: Desc)])
}

model LegalAcceptance {
  id         Int           @id @default(autoincrement())
  userId     Int
  documentId Int
  source     String        @default("settings")
  acceptedAt DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId, acceptedAt(sort: Desc)])
  @@index([documentId, acceptedAt(sort: Desc)])
}

model ShareLink {
  id          Int       @id @default(autoincrement())
  token       String    @unique @default(uuid())
  contentType String // "sheet" or "note"
  contentId   Int
  createdById Int
  permission  String    @default("view") // "view", "comment", "edit"
  expiresAt   DateTime? // null = never expires
  maxViews    Int? // null = unlimited
  viewCount   Int       @default(0)
  password    String? // optional password protection
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  createdBy User @relation("ShareLinkCreator", fields: [createdById], references: [id])

  @@index([token])
  @@index([contentType, contentId])
  @@index([createdById])
}

model ContentShare {
  id           Int      @id @default(autoincrement())
  contentType  String // "sheet" or "note"
  contentId    Int
  sharedById   Int
  sharedWithId Int
  permission   String   @default("view") // "view", "comment", "edit"
  createdAt    DateTime @default(now())

  sharedBy   User @relation("ContentSharedBy", fields: [sharedById], references: [id])
  sharedWith User @relation("ContentSharedWith", fields: [sharedWithId], references: [id])

  @@unique([contentType, contentId, sharedWithId])
  @@index([sharedWithId, contentType])
}

model School {
  id          Int                    @id @default(autoincrement())
  name        String                 @unique
  short       String                 @unique
  city        String                 @default("")
  state       String                 @default("MD")
  schoolType  String                 @default("public")
  logoUrl     String?
  emailDomain String?
  courses     Course[]
  enrollments UserSchoolEnrollment[]
}

model Course {
  id          Int          @id @default(autoincrement())
  schoolId    Int
  name        String
  code        String
  department  String       @default("")
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studySheets StudySheet[]
  enrollments Enrollment[]
  notes       Note[]
  feedPosts   FeedPost[]
  studyGroups StudyGroup[]
  courseExams CourseExam[]
  sections    Section[]

  @@unique([schoolId, code])
}

model Enrollment {
  id       Int    @id @default(autoincrement())
  userId   Int
  courseId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// UserSchoolEnrollment — Phase R1 / Task #64 additive table.
//
// Direct user <-> school membership. The legacy Enrollment model is
// course-level only; school membership is currently inferred via
// course.school. This table will eventually own that relationship to
// support dual-enrolled and self-learner users (browsing multiple
// schools without being enrolled in any of their courses).
//
// As of Phase R1 (this migration) the table exists but is not read
// from anywhere. R2 backfills from existing course enrollments. R3
// switches read paths and deprecates the inference.
//
// `role` is a String (not enum) so future "alumni", "teacher",
// "self-learner" values can be added without a schema migration.
model UserSchoolEnrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  schoolId  Int
  role      String   @default("student") @db.VarChar(32)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([schoolId])
}

model StudySheet {
  id                     Int          @id @default(autoincrement())
  title                  String
  content                String
  contentFormat          String       @default("markdown")
  status                 String       @default("published")
  htmlScanStatus         String       @default("queued")
  htmlScanFindings       Json?
  htmlScanUpdatedAt      DateTime?
  htmlScanAcknowledgedAt DateTime?
  htmlRiskTier           Int          @default(0)
  htmlOriginalArchivedAt DateTime?
  reviewedById           Int?
  reviewedAt             DateTime?
  reviewReason           String?
  reviewFindingsSnapshot Json?
  courseId               Int
  userId                 Int
  forkOf                 Int?
  rootSheetId            Int?
  stars                  Int          @default(0)
  downloads              Int          @default(0)
  forks                  Int          @default(0)
  description            String       @default("")
  previewText            String?      @db.VarChar(280)
  attachmentUrl          String?
  attachmentType         String?
  attachmentName         String?
  allowDownloads         Boolean      @default(true)
  allowEditing           Boolean      @default(false)
  contentHash            String?
  contentSimhash         String?
  aiReviewDecision       String? // "approve", "reject", "escalate", null
  aiReviewConfidence     Int? // 0-100
  aiReviewScore          Int? // 0-100 risk score
  aiReviewFindings       String?      @db.Text // JSON findings array
  aiReviewReasoning      String?      @db.Text // 1-3 sentence reasoning
  aiReviewedAt           DateTime?
  lastAuditGrade         String?      @db.VarChar(1)
  lastAuditReport        Json?
  lastAuditedAt          DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  course                 Course       @relation(fields: [courseId], references: [id])
  author                 User         @relation(fields: [userId], references: [id])
  reviewedBy             User?        @relation("SheetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  forkSource             StudySheet?  @relation("SheetForks", fields: [forkOf], references: [id])
  forkChildren           StudySheet[] @relation("SheetForks")

  comments              Comment[]
  starredBy             StarredSheet[]
  reactions             Reaction[]
  incomingContributions SheetContribution[] @relation("ContributionTarget")
  outgoingContributions SheetContribution[] @relation("ContributionFork")
  plagiarismReports     PlagiarismReport[]  @relation("PlagiarismReportSheet")
  plagiarismMatches     PlagiarismReport[]  @relation("PlagiarismReportMatched")
  htmlVersions          SheetHtmlVersion[]
  commits               SheetCommit[]
  provenance            ProvenanceManifest?
  pinnedBy              UserPinnedSheet[]
  aiReviewLogs          AiReviewLog[]
  studyStatuses         StudyStatus[]
  materials             Material[]          @relation("MaterialSheet")

  @@index([createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([htmlScanStatus, updatedAt(sort: Desc)])
  @@index([htmlRiskTier, status, createdAt(sort: Desc)])
  @@index([contentHash])
  @@index([contentSimhash])
  @@index([aiReviewDecision])
}

model SheetHtmlVersion {
  id                Int        @id @default(autoincrement())
  sheetId           Int
  userId            Int
  kind              String
  sourceName        String?
  content           String
  checksum          String
  compressionAlgo   String?
  compressedContent Bytes?
  archivedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  sheet             StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sheetId, kind])
  @@index([kind, updatedAt(sort: Desc)])
  @@index([archivedAt, updatedAt(sort: Desc)])
}

model RequestedCourse {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  schoolId  Int?
  count     Int      @default(1)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

model Comment {
  id               Int                 @id @default(autoincrement())
  content          String
  sheetId          Int
  userId           Int
  parentId         Int?
  moderationStatus String              @default("clean")
  createdAt        DateTime            @default(now())
  sheet            StudySheet          @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Comment?            @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Comment[]           @relation("CommentReplies")
  reactions        CommentReaction[]
  attachments      CommentAttachment[]

  @@index([sheetId, createdAt(sort: Desc)])
  @@index([parentId])
}

model CommentAttachment {
  id        Int      @id @default(autoincrement())
  commentId Int
  url       String
  type      String
  name      String   @default("")
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model StarredSheet {
  userId  Int
  sheetId Int
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
  @@unique([userId, sheetId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        Int                 @id @default(autoincrement())
  title     String
  body      String
  authorId  Int
  pinned    Boolean             @default(false)
  createdAt DateTime            @default(now())
  author    User                @relation(fields: [authorId], references: [id])
  media     AnnouncementMedia[]

  @@index([pinned, createdAt(sort: Desc)])
}

model Note {
  id               Int            @id @default(autoincrement())
  title            String
  content          String         @default("")
  userId           Int
  courseId         Int?
  private          Boolean        @default(true)
  allowDownloads   Boolean        @default(false)
  pinned           Boolean        @default(false)
  tags             String         @default("[]")
  moderationStatus String         @default("clean")
  contentHash      String?
  contentSimhash   String?
  lastAuditGrade   String?        @db.VarChar(1)
  lastAuditReport  Json?
  lastAuditedAt    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  author           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course?        @relation(fields: [courseId], references: [id])
  downloads        Int            @default(0)
  noteComments     NoteComment[]
  noteStars        NoteStar[]
  noteVersions     NoteVersion[]
  noteReactions    NoteReaction[]
  materials        Material[]     @relation("MaterialNote")
  revision         Int            @default(0)
  lastSaveId       String?        @db.Uuid
}

model NoteComment {
  id               Int                     @id @default(autoincrement())
  content          String
  noteId           Int
  userId           Int
  parentId         Int?
  anchorText       String?
  anchorOffset     Int?
  anchorContext    String?
  resolved         Boolean                 @default(false)
  moderationStatus String                  @default("clean")
  createdAt        DateTime                @default(now())
  note             Note                    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           NoteComment?            @relation("NoteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          NoteComment[]           @relation("NoteCommentReplies")
  reactions        NoteCommentReaction[]
  attachments      NoteCommentAttachment[]

  @@index([noteId, createdAt(sort: Desc)])
  @@index([parentId])
}

model NoteCommentAttachment {
  id        Int         @id @default(autoincrement())
  commentId Int
  url       String
  type      String
  name      String      @default("")
  createdAt DateTime    @default(now())
  comment   NoteComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model NoteStar {
  userId    Int
  noteId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
}

model NoteVersion {
  id              Int             @id @default(autoincrement())
  noteId          Int
  userId          Int
  title           String
  content         String
  message         String?
  createdAt       DateTime        @default(now())
  revision        Int             @default(0)
  parentVersionId Int?
  kind            NoteVersionKind @default(AUTO)
  bytesContent    Int             @default(0)
  note            Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
  @@index([noteId, createdAt], map: "NoteVersion_noteId_createdAt_hard_idx")
}

enum NoteVersionKind {
  AUTO
  MANUAL
  PRE_RESTORE
  CONFLICT_LOSER
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  message   String
  read      Boolean  @default(false)
  priority  String   @default("medium")
  actorId   Int?
  sheetId   Int?
  linkPath  String?
  createdAt DateTime @default(now())
  user      User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([userId, type, actorId, sheetId, createdAt(sort: Desc)], map: "Notification_fanout_dedup_idx")
}

model UserFollow {
  followerId  Int
  followingId Int
  status      String   @default("active") // "active" or "pending" (for private accounts)
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId, status])
}

model Reaction {
  userId  Int
  sheetId Int
  type    String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
}

model DeletionReason {
  id        Int      @id @default(autoincrement())
  username  String
  reason    String
  details   String?
  createdAt DateTime @default(now())
}

model FeedPost {
  id               Int                @id @default(autoincrement())
  content          String
  userId           Int
  courseId         Int?
  attachmentUrl    String?
  attachmentType   String?
  attachmentName   String?
  allowDownloads   Boolean            @default(true)
  videoId          Int?
  moderationStatus String             @default("clean")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  author           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  video            Video?             @relation("FeedPostVideo", fields: [videoId], references: [id], onDelete: SetNull)
  comments         FeedPostComment[]
  reactions        FeedPostReaction[]

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
}

model FeedPostComment {
  id               Int                         @id @default(autoincrement())
  content          String
  postId           Int
  userId           Int
  parentId         Int?
  moderationStatus String                      @default("clean")
  createdAt        DateTime                    @default(now())
  post             FeedPost                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           FeedPostComment?            @relation("FeedPostCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          FeedPostComment[]           @relation("FeedPostCommentReplies")
  reactions        FeedPostCommentReaction[]
  attachments      FeedPostCommentAttachment[]

  @@index([postId, createdAt(sort: Desc)])
  @@index([parentId])
}

model FeedPostCommentAttachment {
  id        Int             @id @default(autoincrement())
  commentId Int
  url       String
  type      String
  name      String          @default("")
  createdAt DateTime        @default(now())
  comment   FeedPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model FeedPostReaction {
  userId Int
  postId Int
  type   String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, type])
}

model SheetContribution {
  id            Int                   @id @default(autoincrement())
  targetSheetId Int
  forkSheetId   Int
  proposerId    Int
  reviewerId    Int?
  status        String                @default("pending")
  message       String                @default("")
  reviewComment String                @default("")
  baseChecksum  String                @default("")
