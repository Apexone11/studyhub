generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int       @id @default(autoincrement())
  username                String    @unique
  passwordHash            String
  role                    String    @default("student")
  trustLevel              String    @default("new")
  trustedAt               DateTime?
  email                   String?   @unique
  emailHash               String?
  emailVerified           Boolean   @default(false)
  isStaffVerified         Boolean   @default(false)
  emailVerificationCode   String?
  emailVerificationExpiry DateTime?
  failedAttempts          Int       @default(0)
  lockedUntil             DateTime?
  avatarUrl               String?
  coverImageUrl           String?
  twoFaEnabled            Boolean   @default(false)
  twoFaCode               String?
  twoFaExpiry             DateTime?
  googleId                String?   @unique
  authProvider            String    @default("local")
  accountType             String    @default("student")
  createdAt               DateTime  @default(now())

  studySheets                StudySheet[]
  enrollments                Enrollment[]
  comments                   Comment[]
  starredSheets              StarredSheet[]
  passwordResetToken         PasswordResetToken?
  announcements              Announcement[]
  notes                      Note[]
  noteComments               NoteComment[]
  noteStars                  NoteStar[]
  noteVersions               NoteVersion[]
  reactions                  Reaction[]
  feedPosts                  FeedPost[]
  feedPostComments           FeedPostComment[]
  feedPostReactions          FeedPostReaction[]
  proposedContributions      SheetContribution[]       @relation("ContributionProposer")
  reviewedContributions      SheetContribution[]       @relation("ContributionReviewer")
  verificationChallenges     VerificationChallenge[]
  notificationsReceived      Notification[]            @relation("NotifRecipient")
  notificationsSent          Notification[]            @relation("NotifActor")
  following                  UserFollow[]              @relation("Following")
  followers                  UserFollow[]              @relation("Followers")
  htmlVersions               SheetHtmlVersion[]
  suppressionAuditsPerformed EmailSuppressionAudit[]   @relation("EmailSuppressionAuditActor")
  preferences                UserPreferences?
  strikes                    Strike[]
  appeals                    Appeal[]
  restrictions               UserRestriction[]
  moderationCases            ModerationCase[]          @relation("ModerationCaseAuthor")
  moderationReviews          ModerationCase[]          @relation("ModerationReviewer")
  moderationReports          ModerationCase[]          @relation("ModerationReporter")
  moderationClaims           ModerationCase[]          @relation("ModerationClaimer")
  appealReviews              Appeal[]                  @relation("AppealReviewer")
  moderationLogs             ModerationLog[]           @relation("ModerationLogUser")
  sheetCommits               SheetCommit[]
  webauthnCredentials        WebAuthnCredential[]
  reviewedSheets             StudySheet[]              @relation("SheetReviewer")
  pinnedSheets               UserPinnedSheet[]
  dailyActivity              UserDailyActivity[]
  badges                     UserBadge[]
  sensitiveData              UserSensitive?
  blockedUsers               UserBlock[]               @relation("BlockedByUser")
  blockedByUsers             UserBlock[]               @relation("BlockedUser")
  mutedUsers                 UserMute[]                @relation("MutedByUser")
  mutedByUsers               UserMute[]                @relation("MutedUser")
  conversationsCreated       Conversation[]            @relation("ConversationCreator")
  conversationParticipants   ConversationParticipant[]
  messagesSent               Message[]                 @relation("MessageSender")
  messageReactions           MessageReaction[]         @relation("MessageReactionUser")
  messagePollVotes           MessagePollVote[]
  studyGroupsCreated         StudyGroup[]              @relation("StudyGroupCreator")
  studyGroupMemberships      StudyGroupMember[]
  groupResources             GroupResource[]
  groupSessionRsvps          GroupSessionRsvp[]
  groupDiscussionPosts       GroupDiscussionPost[]
  groupDiscussionReplies     GroupDiscussionReply[]
  discussionUpvotes          DiscussionUpvote[]
  shareLinksCreated          ShareLink[]               @relation("ShareLinkCreator")
  contentSharedBy            ContentShare[]            @relation("ContentSharedBy")
  contentSharedWith          ContentShare[]            @relation("ContentSharedWith")
  aiConversations            AiConversation[]
  aiMessages                 AiMessage[]               @relation("AiMessageUser")
  aiUsageLogs                AiUsageLog[]
  bookShelves                BookShelf[]
  readingProgress            ReadingProgress[]
  bookBookmarks              BookBookmark[]
  bookHighlights             BookHighlight[]

  @@index([role])
  @@index([emailHash])
}

model ShareLink {
  id          Int       @id @default(autoincrement())
  token       String    @unique @default(uuid())
  contentType String                          // "sheet" or "note"
  contentId   Int
  createdById Int
  permission  String    @default("view")      // "view", "comment", "edit"
  expiresAt   DateTime?                       // null = never expires
  maxViews    Int?                            // null = unlimited
  viewCount   Int       @default(0)
  password    String?                         // optional password protection
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  createdBy User @relation("ShareLinkCreator", fields: [createdById], references: [id])

  @@index([token])
  @@index([contentType, contentId])
  @@index([createdById])
}

model ContentShare {
  id          Int      @id @default(autoincrement())
  contentType String                          // "sheet" or "note"
  contentId   Int
  sharedById  Int
  sharedWithId Int
  permission  String   @default("view")      // "view", "comment", "edit"
  createdAt   DateTime @default(now())

  sharedBy   User @relation("ContentSharedBy", fields: [sharedById], references: [id])
  sharedWith User @relation("ContentSharedWith", fields: [sharedWithId], references: [id])

  @@unique([contentType, contentId, sharedWithId])
  @@index([sharedWithId, contentType])
}

model School {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  short       String   @unique
  city        String   @default("")
  state       String   @default("MD")
  schoolType  String   @default("public")
  logoUrl     String?
  emailDomain String?
  courses     Course[]
}

model Course {
  id          Int          @id @default(autoincrement())
  schoolId    Int
  name        String
  code        String
  department  String       @default("")
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studySheets StudySheet[]
  enrollments Enrollment[]
  notes       Note[]
  feedPosts   FeedPost[]
  studyGroups StudyGroup[]

  @@unique([schoolId, code])
}

model Enrollment {
  id       Int    @id @default(autoincrement())
  userId   Int
  courseId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model StudySheet {
  id                     Int          @id @default(autoincrement())
  title                  String
  content                String
  contentFormat          String       @default("markdown")
  status                 String       @default("published")
  htmlScanStatus         String       @default("queued")
  htmlScanFindings       Json?
  htmlScanUpdatedAt      DateTime?
  htmlScanAcknowledgedAt DateTime?
  htmlRiskTier           Int          @default(0)
  htmlOriginalArchivedAt DateTime?
  reviewedById           Int?
  reviewedAt             DateTime?
  reviewReason           String?
  reviewFindingsSnapshot Json?
  courseId               Int
  userId                 Int
  forkOf                 Int?
  rootSheetId            Int?
  stars                  Int          @default(0)
  downloads              Int          @default(0)
  forks                  Int          @default(0)
  description            String       @default("")
  attachmentUrl          String?
  attachmentType         String?
  attachmentName         String?
  allowDownloads         Boolean      @default(true)
  contentHash            String?
  contentSimhash         String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  course                 Course       @relation(fields: [courseId], references: [id])
  author                 User         @relation(fields: [userId], references: [id])
  reviewedBy             User?        @relation("SheetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  forkSource             StudySheet?  @relation("SheetForks", fields: [forkOf], references: [id])
  forkChildren           StudySheet[] @relation("SheetForks")

  comments              Comment[]
  starredBy             StarredSheet[]
  reactions             Reaction[]
  incomingContributions SheetContribution[] @relation("ContributionTarget")
  outgoingContributions SheetContribution[] @relation("ContributionFork")
  htmlVersions          SheetHtmlVersion[]
  commits               SheetCommit[]
  provenance            ProvenanceManifest?
  pinnedBy              UserPinnedSheet[]

  @@index([createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([htmlScanStatus, updatedAt(sort: Desc)])
  @@index([htmlRiskTier, status, createdAt(sort: Desc)])
  @@index([contentHash])
  @@index([contentSimhash])
}

model SheetHtmlVersion {
  id                Int        @id @default(autoincrement())
  sheetId           Int
  userId            Int
  kind              String
  sourceName        String?
  content           String
  checksum          String
  compressionAlgo   String?
  compressedContent Bytes?
  archivedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  sheet             StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sheetId, kind])
  @@index([kind, updatedAt(sort: Desc)])
  @@index([archivedAt, updatedAt(sort: Desc)])
}

model RequestedCourse {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  schoolId  Int?
  count     Int      @default(1)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

model Comment {
  id               Int        @id @default(autoincrement())
  content          String
  sheetId          Int
  userId           Int
  moderationStatus String     @default("clean")
  createdAt        DateTime   @default(now())
  sheet            StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sheetId, createdAt(sort: Desc)])
}

model StarredSheet {
  userId  Int
  sheetId Int
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
  @@unique([userId, sheetId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  authorId  Int
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])

  @@index([pinned, createdAt(sort: Desc)])
}

model Note {
  id               Int           @id @default(autoincrement())
  title            String
  content          String        @default("")
  userId           Int
  courseId         Int?
  private          Boolean       @default(true)
  allowDownloads   Boolean       @default(false)
  pinned           Boolean       @default(false)
  tags             String        @default("[]")
  moderationStatus String        @default("clean")
  contentHash      String?
  contentSimhash   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  author           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course?       @relation(fields: [courseId], references: [id])
  noteComments     NoteComment[]
  noteStars        NoteStar[]
  noteVersions     NoteVersion[]
}

model NoteComment {
  id               Int      @id @default(autoincrement())
  content          String
  noteId           Int
  userId           Int
  anchorText       String?
  anchorOffset     Int?
  anchorContext    String?
  resolved         Boolean  @default(false)
  moderationStatus String   @default("clean")
  createdAt        DateTime @default(now())
  note             Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
}

model NoteStar {
  userId    Int
  noteId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
}

model NoteVersion {
  id        Int      @id @default(autoincrement())
  noteId    Int
  userId    Int
  title     String
  content   String
  message   String?
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  message   String
  read      Boolean  @default(false)
  priority  String   @default("medium")
  actorId   Int?
  sheetId   Int?
  linkPath  String?
  createdAt DateTime @default(now())
  user      User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt(sort: Desc)])
}

model UserFollow {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Reaction {
  userId  Int
  sheetId Int
  type    String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
}

model DeletionReason {
  id        Int      @id @default(autoincrement())
  username  String
  reason    String
  details   String?
  createdAt DateTime @default(now())
}

model FeedPost {
  id               Int                @id @default(autoincrement())
  content          String
  userId           Int
  courseId         Int?
  attachmentUrl    String?
  attachmentType   String?
  attachmentName   String?
  allowDownloads   Boolean            @default(true)
  moderationStatus String             @default("clean")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  author           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  comments         FeedPostComment[]
  reactions        FeedPostReaction[]

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
}

model FeedPostComment {
  id               Int      @id @default(autoincrement())
  content          String
  postId           Int
  userId           Int
  moderationStatus String   @default("clean")
  createdAt        DateTime @default(now())
  post             FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt(sort: Desc)])
}

model FeedPostReaction {
  userId Int
  postId Int
  type   String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, type])
}

model SheetContribution {
  id            Int        @id @default(autoincrement())
  targetSheetId Int
  forkSheetId   Int
  proposerId    Int
  reviewerId    Int?
  status        String     @default("pending")
  message       String     @default("")
  reviewComment String     @default("")
  baseChecksum  String     @default("")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  reviewedAt    DateTime?
  targetSheet   StudySheet @relation("ContributionTarget", fields: [targetSheetId], references: [id], onDelete: Cascade)
  forkSheet     StudySheet @relation("ContributionFork", fields: [forkSheetId], references: [id], onDelete: Cascade)
  proposer      User       @relation("ContributionProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  reviewer      User?      @relation("ContributionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([targetSheetId, status])
  @@index([proposerId, status])
}

model VerificationChallenge {
  id           Int       @id @default(autoincrement())
  token        String    @unique
  purpose      String
  userId       Int?
  username     String?
  email        String?
  passwordHash String?
  payload      Json?
  codeHash     String
  expiresAt    DateTime
  attemptCount Int       @default(0)
  sendCount    Int       @default(1)
  lastSentAt   DateTime  @default(now())
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([purpose, userId, expiresAt])
  @@index([purpose, username, expiresAt])
  @@index([purpose, email, expiresAt])
  @@index([purpose, verifiedAt, expiresAt])
}

model EmailDeliveryEvent {
  id                Int       @id @default(autoincrement())
  provider          String
  eventType         String
  providerWebhookId String?   @unique
  providerMessageId String?
  recipient         String?
  subject           String?
  eventCreatedAt    DateTime?
  payload           Json
  receivedAt        DateTime  @default(now())

  @@index([provider, eventType, receivedAt(sort: Desc)])
  @@index([providerMessageId, receivedAt(sort: Desc)])
  @@index([recipient, receivedAt(sort: Desc)])
}

model EmailSuppression {
  id                Int                     @id @default(autoincrement())
  email             String                  @unique
  active            Boolean                 @default(true)
  reason            String
  provider          String
  sourceEventType   String
  sourceEventId     String?
  sourceMessageId   String?
  details           Json?
  firstSuppressedAt DateTime                @default(now())
  lastSuppressedAt  DateTime                @default(now())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  audits            EmailSuppressionAudit[]

  @@index([active, updatedAt(sort: Desc)])
  @@index([provider, active, updatedAt(sort: Desc)])
}

model EmailSuppressionAudit {
  id                Int              @id @default(autoincrement())
  suppressionId     Int
  action            String
  reason            String
  performedByUserId Int?
  context           Json?
  createdAt         DateTime         @default(now())
  suppression       EmailSuppression @relation(fields: [suppressionId], references: [id], onDelete: Cascade)
  performedBy       User?            @relation("EmailSuppressionAuditActor", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([suppressionId, createdAt(sort: Desc)])
  @@index([performedByUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

model UserPreferences {
  id                   Int     @id @default(autoincrement())
  userId               Int     @unique
  emailDigest          Boolean @default(true)
  emailMentions        Boolean @default(true)
  emailContributions   Boolean @default(true)
  inAppNotifications   Boolean @default(true)
  profileVisibility    String  @default("public")
  defaultDownloads     Boolean @default(true)
  defaultContributions Boolean @default(true)
  theme                String  @default("system")
  fontSize             String  @default("medium")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ModerationCase {
  id               Int                  @id @default(autoincrement())
  contentType      String
  contentId        Int
  userId           Int?
  status           String               @default("pending")
  confidence       Float?
  category         String?
  provider         String?
  evidence         Json?
  reviewedBy       Int?
  reviewNote       String?
  source           String               @default("auto")
  reporterUserId   Int?
  reasonCategory   String?
  excerpt          String?
  claimedByAdminId Int?
  claimedAt        DateTime?
  contentPurged    Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User?                @relation("ModerationCaseAuthor", fields: [userId], references: [id], onDelete: SetNull)
  reviewer         User?                @relation("ModerationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reporter         User?                @relation("ModerationReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  claimedBy        User?                @relation("ModerationClaimer", fields: [claimedByAdminId], references: [id], onDelete: SetNull)
  strikes          Strike[]
  appeals          Appeal[]
  snapshots        ModerationSnapshot[]

  @@index([status, createdAt(sort: Desc)])
  @@index([contentType, contentId])
  @@index([userId])
  @@index([source, status])
  @@index([claimedByAdminId])
}

model Strike {
  id        Int             @id @default(autoincrement())
  userId    Int
  reason    String
  caseId    Int?
  issuedAt  DateTime        @default(now())
  expiresAt DateTime
  decayedAt DateTime?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  case      ModerationCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId, decayedAt, expiresAt])
}

model Appeal {
  id             Int            @id @default(autoincrement())
  caseId         Int
  userId         Int
  reasonCategory String?
  reason         String
  status         String         @default("pending")
  reviewedBy     Int?
  reviewNote     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  case           ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer       User?          @relation("AppealReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([userId, status])
}

model ModerationSnapshot {
  id                   Int            @id @default(autoincrement())
  caseId               Int
  targetType           String
  targetId             Int
  ownerId              Int?
  contentJson          Json
  attachmentUrl        String?
  createdAt            DateTime       @default(now())
  restoredAt           DateTime?
  permanentlyDeletedAt DateTime?
  case                 ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([targetType, targetId])
}

model ModerationLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String
  caseId      Int?
  strikeId    Int?
  appealId    Int?
  contentType String?
  contentId   Int?
  reason      String?
  performedBy Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation("ModerationLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([caseId])
}

model UserRestriction {
  id       Int       @id @default(autoincrement())
  userId   Int
  type     String
  startsAt DateTime  @default(now())
  endsAt   DateTime?
  reason   String?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endsAt])
}

// ── Sheet Lab: version control commits ──────────────────────
model SheetCommit {
  id            Int           @id @default(autoincrement())
  sheetId       Int
  userId        Int
  kind          String        @default("snapshot")
  message       String        @default("")
  content       String
  contentFormat String        @default("markdown")
  checksum      String
  parentId      Int?
  createdAt     DateTime      @default(now())
  sheet         StudySheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        SheetCommit?  @relation("CommitHistory", fields: [parentId], references: [id])
  children      SheetCommit[] @relation("CommitHistory")

  @@index([sheetId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ── Provenance: encrypted origin manifests ──────────────────
model ProvenanceManifest {
  id             Int        @id @default(autoincrement())
  sheetId        Int        @unique
  originHash     String
  encryptedToken String
  algorithm      String     @default("aes-256-gcm")
  iv             String
  authTag        String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  sheet          StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
}

// ── Profile: pinned sheets ──────────────────────────────────
model UserPinnedSheet {
  id       Int        @id @default(autoincrement())
  userId   Int
  sheetId  Int
  position Int        @default(0)
  pinnedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet    StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([userId, sheetId])
  @@index([userId, position])
}

// ── Profile: daily activity for contribution graph ──────────
model UserDailyActivity {
  id       Int      @id @default(autoincrement())
  userId   Int
  date     DateTime @db.Date
  commits  Int      @default(0)
  sheets   Int      @default(0)
  reviews  Int      @default(0)
  comments Int      @default(0)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
}

// ── Achievements: badge catalog & unlocks ───────────────────
model Badge {
  id          Int         @id @default(autoincrement())
  slug        String      @unique
  name        String
  description String
  category    String
  tier        String      @default("bronze")
  iconUrl     String?
  threshold   Int         @default(1)
  createdAt   DateTime    @default(now())
  unlocks     UserBadge[]
}

model UserBadge {
  id         Int      @id @default(autoincrement())
  userId     Int
  badgeId    Int
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId, unlockedAt(sort: Desc)])
}

// ── Feature flags ───────────────────────────────────────────
model FeatureFlag {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String   @default("")
  enabled           Boolean  @default(false)
  rolloutPercentage Int      @default(0)
  conditions        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Audit Log (sensitive operations) ────────────────────────
model AuditLog {
  id           Int      @id @default(autoincrement())
  event        String
  actorId      Int?
  actorRole    String?
  targetUserId Int?
  route        String?
  method       String?
  createdAt    DateTime @default(now())

  @@index([event])
  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
}

// ── PII Vault (envelope-encrypted sensitive data) ───────────
model UserSensitive {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  ciphertext       String
  encryptedDataKey String
  keyArn           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── WebAuthn passkey credentials ────────────────────────────
model WebAuthnCredential {
  id           Int      @id @default(autoincrement())
  userId       Int
  credentialId String   @unique
  publicKey    Bytes
  counter      Int      @default(0)
  deviceType   String?
  backedUp     Boolean  @default(false)
  transports   String?
  name         String   @default("Passkey")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserBlock {
  blockerId Int
  blockedId Int
  reason    String?
  createdAt DateTime @default(now())
  blocker   User     @relation("BlockedByUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model UserMute {
  muterId   Int
  mutedId   Int
  createdAt DateTime @default(now())
  muter     User     @relation("MutedByUser", fields: [muterId], references: [id], onDelete: Cascade)
  muted     User     @relation("MutedUser", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([muterId, mutedId])
  @@index([mutedId])
}

// ═══════════════════════════════════════════════════════════════════════════
// StudyHub Connect — Real-time Messaging
// ═══════════════════════════════════════════════════════════════════════════

model Conversation {
  id          Int      @id @default(autoincrement())
  type        String   @default("dm") // "dm" or "group"
  name        String? // display name for group chats
  avatarUrl   String? // custom avatar for group chats
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
}

model ConversationParticipant {
  conversationId Int
  userId         Int
  role           String   @default("member") // "member" or "admin" (group only)
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now()) // for read receipts
  muted          Boolean  @default(false) // mute notifications for this convo
  archived       Boolean  @default(false) // hide from main list

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, archived])
}

model Message {
  id             Int       @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String    @db.Text
  type           String    @default("text") // "text", "image", "system"
  replyToId      Int? // thread replies
  editedAt       DateTime?
  deletedAt      DateTime? // soft delete
  createdAt      DateTime  @default(now())

  conversation  Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User               @relation("MessageSender", fields: [senderId], references: [id])
  replyTo       Message?           @relation("MessageReply", fields: [replyToId], references: [id])
  replies       Message[]          @relation("MessageReply")
  reactions     MessageReaction[]
  attachments   MessageAttachment[]
  poll          MessagePoll?

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String   @db.VarChar(16) // e.g. "thumbsup", "heart", "laugh"
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageReactionUser", fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageAttachment {
  id        Int       @id @default(autoincrement())
  messageId Int
  type      String    @default("image") // "image", "file", "video"
  url       String
  fileName  String?
  fileSize  Int?
  mimeType  String?
  width     Int?
  height    Int?
  createdAt DateTime  @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessagePoll {
  id             Int       @id @default(autoincrement())
  messageId      Int       @unique
  question       String
  allowMultiple  Boolean   @default(false)
  closedAt       DateTime?
  createdAt      DateTime  @default(now())

  message Message                @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options MessagePollOption[]
  votes   MessagePollVote[]
}

model MessagePollOption {
  id       Int    @id @default(autoincrement())
  pollId   Int
  text     String
  position Int    @default(0)

  poll  MessagePoll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes MessagePollVote[]

  @@index([pollId])
}

model MessagePollVote {
  pollId   Int
  optionId Int
  userId   Int
  createdAt DateTime @default(now())

  poll   MessagePoll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option MessagePollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, optionId, userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// Study Groups — Collaborative study sessions and resource sharing
// ═══════════════════════════════════════════════════════════════════════════

model StudyGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  avatarUrl   String?
  courseId    Int? // null = freeform group
  privacy     String   @default("public") // "public", "private", "invite_only"
  maxMembers  Int      @default(50)
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course    Course?               @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy User                  @relation("StudyGroupCreator", fields: [createdById], references: [id])
  members   StudyGroupMember[]
  resources GroupResource[]
  sessions  GroupSession[]
  posts     GroupDiscussionPost[]

  @@index([courseId])
  @@index([privacy, updatedAt(sort: Desc)])
  @@index([createdById])
}

model StudyGroupMember {
  id       Int      @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     String   @default("member") // "admin", "moderator", "member"
  status   String   @default("active") // "active", "pending", "invited", "banned"
  joinedAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, status])
  @@index([groupId, status])
}

model GroupResource {
  id           Int      @id @default(autoincrement())
  groupId      Int
  userId       Int // who added it
  title        String
  description  String   @default("")
  resourceType String   @default("link") // "link", "sheet", "note", "file"
  resourceUrl  String? // external link or file path
  sheetId      Int? // linked StudySheet
  noteId       Int? // linked Note
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, pinned, createdAt(sort: Desc)])
}

model GroupSession {
  id           Int      @id @default(autoincrement())
  groupId      Int
  title        String
  description  String   @default("")
  location     String   @default("") // room, zoom link, etc.
  scheduledAt  DateTime
  durationMins Int      @default(60)
  recurring    String? // "weekly", "biweekly", null
  status       String   @default("upcoming") // "upcoming", "in_progress", "completed", "cancelled"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group StudyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rsvps GroupSessionRsvp[]

  @@index([groupId, scheduledAt(sort: Desc)])
  @@index([scheduledAt])
}

model GroupSessionRsvp {
  id        Int      @id @default(autoincrement())
  sessionId Int
  userId    Int
  status    String   @default("going") // "going", "maybe", "not_going"
  createdAt DateTime @default(now())

  session GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, status])
}

model GroupDiscussionPost {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  title     String
  content   String   @db.Text
  type      String   @default("discussion") // "discussion", "question", "announcement", "poll"
  pinned    Boolean  @default(false)
  resolved  Boolean  @default(false) // for Q&A threads
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group   StudyGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies GroupDiscussionReply[]
  upvotes DiscussionUpvote[]

  @@index([groupId, pinned, createdAt(sort: Desc)])
  @@index([groupId, type, createdAt(sort: Desc)])
}

model GroupDiscussionReply {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String   @db.Text
  isAnswer  Boolean  @default(false) // mark as accepted answer for Q&A
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    GroupDiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  upvotes DiscussionUpvote[]

  @@index([postId, createdAt])
}

model DiscussionUpvote {
  id        Int      @id @default(autoincrement())
  postId    Int?
  replyId   Int?
  userId    Int
  createdAt DateTime @default(now())

  post  GroupDiscussionPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply GroupDiscussionReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([replyId, userId])
  @@index([postId])
  @@index([replyId])
}

// ── Hub AI ──────────────────────────────────────────────────────────

model AiConversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String?
  model     String   @default("claude-sonnet-4-20250514")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model AiMessage {
  id               Int      @id @default(autoincrement())
  conversationId   Int
  role             String   // "user" or "assistant"
  content          String
  hasImage         Boolean  @default(false)
  imageDescription String?
  tokenCount       Int?
  model            String?
  metadata         Json?
  createdAt        DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?          @relation("AiMessageUser", fields: [userId], references: [id], onDelete: Cascade)
  userId       Int?

  @@index([conversationId, createdAt])
}

model AiUsageLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  date         DateTime @db.Date
  messageCount Int      @default(0)
  tokenCount   Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ── Library / BookHub models ──────────────────────────────────

model BookShelf {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  books ShelfBook[]

  @@unique([userId, name])
  @@index([userId])
}

model ShelfBook {
  id       Int      @id @default(autoincrement())
  shelfId  Int
  volumeId String
  title    String
  author   String
  coverUrl String?
  addedAt  DateTime @default(now())

  shelf BookShelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@unique([shelfId, volumeId])
  @@index([shelfId])
}

model ReadingProgress {
  id         Int      @id @default(autoincrement())
  userId     Int
  volumeId   String
  cfi        String?
  percentage Float    @default(0)
  lastReadAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, volumeId])
  @@index([userId])
}

model BookBookmark {
  id          Int      @id @default(autoincrement())
  userId      Int
  volumeId    String
  cfi         String
  label       String?
  pageSnippet String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, volumeId])
}

model BookHighlight {
  id        Int      @id @default(autoincrement())
  userId    Int
  volumeId  String
  cfi       String
  text      String
  color     String   @default("#FFEB3B")
  note      String?
  shared    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, volumeId])
  @@index([volumeId, shared])
}

// ── Waitlist ─────────────────────────────────────────────────

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String
  tier      String
  createdAt DateTime @default(now())

  @@unique([email, tier])
  @@index([email])
  @@index([tier])
}

// ── Library Catalog Cache ────────────────────────────────────

model CachedBook {
  id          Int      @id @default(autoincrement())
  volumeId    String   @unique
  title       String
  authors     Json     @default("[]")
  categories  Json     @default("[]")
  language    String   @default("en")
  pageCount   Int      @default(0)
  coverUrl    String?
  previewLink String?
  description String?
  publishedDate String?
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageCount(sort: Desc)])
  @@index([language])
}
