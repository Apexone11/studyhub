generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique
  passwordHash   String
  role           String    @default("student")
  email          String?   @unique
  emailVerified  Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  avatarUrl      String?
  twoFaEnabled   Boolean   @default(false)
  twoFaCode      String?
  twoFaExpiry    DateTime?
  createdAt      DateTime  @default(now())

  studySheets        StudySheet[]
  enrollments        Enrollment[]
  comments           Comment[]
  starredSheets      StarredSheet[]
  passwordResetToken PasswordResetToken?
  announcements      Announcement[]
  notes              Note[]
  reactions          Reaction[]
  notificationsReceived Notification[] @relation("NotifRecipient")
  notificationsSent     Notification[] @relation("NotifActor")
  following          UserFollow[]   @relation("Following")
  followers          UserFollow[]   @relation("Followers")
}

model School {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  short   String
  courses Course[]
}

model Course {
  id           Int          @id @default(autoincrement())
  schoolId     Int
  name         String
  code         String
  school       School       @relation(fields: [schoolId], references: [id])
  studySheets  StudySheet[]
  enrollments  Enrollment[]
  notes        Note[]
}

model Enrollment {
  id       Int    @id @default(autoincrement())
  userId   Int
  courseId Int
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model StudySheet {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  courseId  Int
  userId    Int
  forkOf    Int?
  stars     Int      @default(0)
  downloads Int      @default(0)
  forks          Int      @default(0)
  description    String   @default("")
  attachmentUrl  String?
  attachmentType String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  author    User     @relation(fields: [userId], references: [id])

  comments     Comment[]
  starredBy    StarredSheet[]
  reactions    Reaction[]
}

model RequestedCourse {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  schoolId  Int?
  count     Int      @default(1)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

model Comment {
  id        Int        @id @default(autoincrement())
  content   String
  sheetId   Int
  userId    Int
  createdAt DateTime   @default(now())
  sheet     StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StarredSheet {
  userId  Int
  sheetId Int
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
  @@unique([userId, sheetId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  authorId  Int
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  userId    Int
  courseId  Int?
  private   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?  @relation(fields: [courseId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  message   String
  read      Boolean  @default(false)
  actorId   Int?
  sheetId   Int?
  createdAt DateTime @default(now())
  user      User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model UserFollow {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Reaction {
  userId  Int
  sheetId Int
  type    String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet   StudySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@id([userId, sheetId])
}

model DeletionReason {
  id        Int      @id @default(autoincrement())
  username  String
  reason    String
  details   String?
  createdAt DateTime @default(now())
}
