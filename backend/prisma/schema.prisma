// ═══════════════════════════════════════════════════════════════════════════
// StudyHub Connect — Real-time Messaging
// ═══════════════════════════════════════════════════════════════════════════

model Conversation {
  id          Int      @id @default(autoincrement())
  type        String   @default("dm") // "dm" or "group"
  name        String? // display name for group chats
  avatarUrl   String? // custom avatar for group chats
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
}

model ConversationParticipant {
  conversationId Int
  userId         Int
  role           String   @default("member") // "member" or "admin" (group only)
  status         String   @default("active") // "active", "pending", "declined"
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now()) // for read receipts
  muted          Boolean  @default(false) // mute notifications for this convo
  archived       Boolean  @default(false) // hide from main list

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, archived])
  @@index([userId, status])
}

model Message {
  id             Int       @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String    @db.Text
  type           String    @default("text") // "text", "image", "system"
  replyToId      Int? // thread replies
  editedAt       DateTime?
  deletedAt      DateTime? // soft delete
  createdAt      DateTime  @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("MessageSender", fields: [senderId], references: [id])
  replyTo      Message?            @relation("MessageReply", fields: [replyToId], references: [id])
  replies      Message[]           @relation("MessageReply")
  reactions    MessageReaction[]
  attachments  MessageAttachment[]
  poll         MessagePoll?

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String   @db.VarChar(16) // e.g. "thumbsup", "heart", "laugh"
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageReactionUser", fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageAttachment {
  id        Int      @id @default(autoincrement())
  messageId Int
  type      String   @default("image") // "image", "file", "video"
  url       String
  fileName  String?
  fileSize  Int?
  mimeType  String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessagePoll {
  id            Int       @id @default(autoincrement())
  messageId     Int       @unique
  question      String
  allowMultiple Boolean   @default(false)
  closedAt      DateTime?
  createdAt     DateTime  @default(now())

  message Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options MessagePollOption[]
  votes   MessagePollVote[]
}

model MessagePollOption {
  id       Int    @id @default(autoincrement())
  pollId   Int
  text     String
  position Int    @default(0)

  poll  MessagePoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes MessagePollVote[]

  @@index([pollId])
}

model MessagePollVote {
  pollId    Int
  optionId  Int
  userId    Int
  createdAt DateTime @default(now())

  poll   MessagePoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option MessagePollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, optionId, userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// Study Groups — Collaborative study sessions and resource sharing
// ═══════════════════════════════════════════════════════════════════════════

model StudyGroup {
  id                  Int       @id @default(autoincrement())
  name                String
  description         String    @default("")
  avatarUrl           String?
  // Phase 4: owner-curated background for the group header.
  // `backgroundUrl` is either a relative /uploads/group-media/... path
  // (local dev) or a curated gallery asset path; `backgroundCredit` is
  // an optional freeform attribution line (e.g. "Pexels · Jane Doe").
  backgroundUrl       String?
  backgroundCredit    String?
  courseId            Int? // null = freeform group
  privacy             String    @default("public") // "public", "private", "invite_only"
  maxMembers          Int       @default(50)
  createdById         Int
  // Phase 5 trust & safety:
  //   moderationStatus: 'active' | 'warned' | 'locked' | 'deleted'
  //   warnedUntil: auto-clears a warning banner after this timestamp
  //   lockedAt: set when an admin locks the group (read-only mode)
  //   deletedAt: soft-delete sentinel; a cron sweep hard-deletes after 30 days
  //   deletedById: which admin performed the soft-delete (audit)
  moderationStatus    String    @default("active")
  warnedUntil         DateTime?
  lockedAt            DateTime?
  deletedAt           DateTime?
  deletedById         Int?
  // Phase 5 member-list visibility: when true, non-members cannot see
  // the member roster (admins/mods always see it regardless).
  memberListPrivate   Boolean   @default(false)
  // Phase 5 post-approval queue: when true, new discussion posts enter
  // status 'pending_approval' and only become visible after a mod approves.
  requirePostApproval Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  course     Course?               @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy  User                  @relation("StudyGroupCreator", fields: [createdById], references: [id])
  deletedBy  User?                 @relation("StudyGroupDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  members    StudyGroupMember[]
  resources  GroupResource[]
  sessions   GroupSession[]
  posts      GroupDiscussionPost[]
  mediaUsage GroupMediaUsage[]
  reports    GroupReport[]
  appeals    GroupAppeal[]
  auditLog   GroupAuditLog[]
  blocks     GroupBlock[]

  @@index([courseId])
  @@index([privacy, updatedAt(sort: Desc)])
  @@index([createdById])
  @@index([moderationStatus])
  @@index([deletedAt])
}

model StudyGroupMember {
  id           Int       @id @default(autoincrement())
  groupId      Int
  userId       Int
  role         String    @default("member") // "admin", "moderator", "member"
  status       String    @default("active") // "active", "pending", "invited", "banned"
  joinedAt     DateTime  @default(now())
  // Phase 5: join-gate message. Captured when a user requests to join a
  // private group so admins know why they want in. Cleared on approval.
  joinMessage  String    @default("")
  // Phase 5: mute window. When non-null and in the future, the user can
  // read the group but cannot post/comment/upload. Enforced by the
  // resources + discussions routes. `muteReason` is shown to the user.
  mutedUntil   DateTime?
  mutedReason  String    @default("")
  mutedById    Int?
  // Phase 5: strike counter for two-strikes auto-ban. Incremented when a
  // mod removes the user's post/resource. Auto-ban triggers at 2+ strikes
  // in a 30-day window (computed by service, not DB).
  lastStrikeAt DateTime?
  strikeCount  Int       @default(0)

  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mutedBy User?      @relation("StudyGroupMemberMutedBy", fields: [mutedById], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([userId, status])
  @@index([groupId, status])
  @@index([mutedUntil])
}

model GroupResource {
  id           Int      @id @default(autoincrement())
  groupId      Int
  userId       Int // who added it
  title        String
  description  String   @default("")
  resourceType String   @default("link") // "link", "sheet", "note", "file", "image", "video"
  resourceUrl  String? // external link or file path
  sheetId      Int? // linked StudySheet
  noteId       Int? // linked Note
  pinned       Boolean  @default(false)
  // Phase 4: structured media metadata for direct uploads. Nullable so
  // legacy "link"/"sheet"/"note" resources continue to work unchanged.
  mediaType    String? // "image" | "video" | "file" | "link"
  mediaUrl     String?
  mediaBytes   Int?
  mediaMime    String?
  createdAt    DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, pinned, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
}

model GroupSession {
  id           Int      @id @default(autoincrement())
  groupId      Int
  title        String
  description  String   @default("")
  location     String   @default("") // room, zoom link, etc.
  scheduledAt  DateTime
  durationMins Int      @default(60)
  recurring    String? // "weekly", "biweekly", null
  status       String   @default("upcoming") // "upcoming", "in_progress", "completed", "cancelled"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group StudyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rsvps GroupSessionRsvp[]

  @@index([groupId, scheduledAt(sort: Desc)])
  @@index([scheduledAt])
}

model GroupSessionRsvp {
  id        Int      @id @default(autoincrement())
  sessionId Int
  userId    Int
  status    String   @default("going") // "going", "maybe", "not_going"
  createdAt DateTime @default(now())

  session GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, status])
}

model GroupDiscussionPost {
  id          Int       @id @default(autoincrement())
  groupId     Int
  userId      Int
  title       String
  content     String    @db.Text
  type        String    @default("discussion") // "discussion", "question", "announcement", "poll"
  pinned      Boolean   @default(false)
  resolved    Boolean   @default(false) // for Q&A threads
  // Phase 4: optional media attachments. JSON array of
  //   [{ url, mime, bytes, kind: 'image'|'video'|'file' }]
  attachments Json?
  // Phase 5: moderation status.
  //   'published'       — visible to all members (default)
  //   'pending_approval' — created under require-approval flag, hidden
  //                        until a mod approves; only author + mods see it
  //   'removed'         — a mod removed it; kept for audit, shown as
  //                        "removed by moderator" to members
  status      String    @default("published")
  removedAt   DateTime?
  removedById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  group   StudyGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies GroupDiscussionReply[]
  upvotes DiscussionUpvote[]

  @@index([groupId, pinned, createdAt(sort: Desc)])
  @@index([groupId, type, createdAt(sort: Desc)])
}

model GroupDiscussionReply {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String   @db.Text
  isAnswer  Boolean  @default(false) // mark as accepted answer for Q&A
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    GroupDiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  upvotes DiscussionUpvote[]

  @@index([postId, createdAt])
}

// Phase 4: per-user weekly media upload counter for study groups.
// One row per (user, weekStart) pair. weekStart is the Monday 00:00 UTC
// of the current ISO week. Incremented after every successful upload via
// assertQuotaAvailable + incrementUsage in studyGroups.media.service.
model GroupMediaUsage {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int?
  weekStart DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group StudyGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

// Phase 5: trust & safety — report a group for review.
// Each user can file at most one report per group (the unique index
// enforces this at the DB level). Reports drive the admin review queue
// and auto-lock escalation (5 unique reporters in 24h).
model GroupReport {
  id           Int       @id @default(autoincrement())
  groupId      Int
  reporterId   Int
  reason       String // 'spam' | 'harassment' | 'hate' | 'copyright' | 'impersonation' | 'sexual' | 'other'
  details      String    @default("")
  // Optional evidence attachments (JSON array, same shape as discussion post
  // attachments — { url, mime, bytes, kind }).
  attachments  Json?
  status       String    @default("pending") // 'pending' | 'dismissed' | 'warned' | 'locked' | 'deleted' | 'escalated'
  resolvedAt   DateTime?
  resolvedById Int?
  resolution   String    @default("") // admin internal notes (not shown to reporter or group owner)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  group      StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reporter   User       @relation("GroupReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("GroupReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([groupId, reporterId])
  @@index([status, createdAt])
  @@index([groupId, status])
  @@index([reporterId, status])
}

// Phase 5: group owner appeal after a warn / lock / delete action.
// One appeal per (group, user) pair. Admin accepts (restore) or rejects
// (final). No second appeals.
model GroupAppeal {
  id             Int       @id @default(autoincrement())
  groupId        Int
  appealerId     Int
  originalAction String // 'warned' | 'locked' | 'deleted'
  message        String    @db.Text
  status         String    @default("pending") // 'pending' | 'accepted' | 'rejected'
  resolvedAt     DateTime?
  resolvedById   Int?
  resolution     String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group      StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  appealer   User       @relation("GroupAppealAppealer", fields: [appealerId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("GroupAppealResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([groupId, appealerId])
  @@index([status, createdAt])
}

// Phase 5: per-group audit log. Every mod action (approve/reject post,
// remove post, ban/mute user, change background, warn/lock/delete group,
// approve/reject join request) writes a row here so other mods can see
// who did what and compromised mod accounts can be investigated.
model GroupAuditLog {
  id         Int      @id @default(autoincrement())
  groupId    Int
  // Nullable so system-automated actions (auto-lock, auto-ban) can be
  // recorded without a FK to a real user row.
  actorId    Int?
  action     String // e.g. 'post.remove', 'member.ban', 'group.lock', 'background.change'
  targetType String? // 'post' | 'reply' | 'member' | 'resource' | 'group'
  targetId   Int?
  // Free-form JSON context: previous/next values, mod-entered reason, etc.
  // Always redact sensitive content before writing.
  context    Json?
  // Session fingerprint for compromised-account forensics. Raw IPs are
  // stored without masking; rotate/prune via a retention job.
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User?      @relation("GroupAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action])
}

// Phase 5: group-level user block. Admin/mod blocks a user from joining,
// viewing, or interacting with a specific group. Blocked users see
// "You can't access this group." If they try to join, the join is
// immediately rejected without notifying mods.
model GroupBlock {
  id          Int      @id @default(autoincrement())
  groupId     Int
  userId      Int
  blockedById Int
  reason      String   @default("")
  createdAt   DateTime @default(now())

  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation("GroupBlockUser", fields: [userId], references: [id], onDelete: Cascade)
  blockedBy User       @relation("GroupBlockActor", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model DiscussionUpvote {
  id        Int      @id @default(autoincrement())
  postId    Int?
  replyId   Int?
  userId    Int
  createdAt DateTime @default(now())

  post  GroupDiscussionPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply GroupDiscussionReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([replyId, userId])
  @@index([postId])
  @@index([replyId])
}

// ── Hub AI ──────────────────────────────────────────────────────────

model AiConversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String?
  model     String   @default("claude-sonnet-4-20250514")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model AiMessage {
  id               Int      @id @default(autoincrement())
  conversationId   Int
  role             String // "user" or "assistant"
  content          String
  hasImage         Boolean  @default(false)
  imageDescription String?
  tokenCount       Int?
  model            String?
  metadata         Json?
  createdAt        DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?          @relation("AiMessageUser", fields: [userId], references: [id], onDelete: Cascade)
