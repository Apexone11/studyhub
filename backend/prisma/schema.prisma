model Subscription {
  id                   Int       @id @default(autoincrement())
  userId               Int
  stripeCustomerId     String
  stripeSubscriptionId String    @unique
  stripePriceId        String
  plan                 String    @default("free") // "free", "pro_monthly", "pro_yearly"
  status               String    @default("active") // "active", "past_due", "canceled", "incomplete", "trialing"
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([userId])
  @@index([stripeCustomerId])
  @@index([status])
}

model Payment {
  id                    Int      @id @default(autoincrement())
  userId                Int
  subscriptionId        Int?
  stripePaymentIntentId String?  @unique
  stripeInvoiceId       String?  @unique
  amount                Int // cents
  currency              String   @default("usd") @db.VarChar(3)
  status                String // "succeeded", "failed", "pending", "refunded"
  description           String?
  receiptUrl            String?
  type                  String   @default("subscription") // "subscription", "donation"
  createdAt             DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type])
  @@index([status])
}

model Donation {
  id                    Int      @id @default(autoincrement())
  userId                Int?
  stripeSessionId       String   @unique
  stripePaymentIntentId String?  @unique
  amount                Int // cents
  currency              String   @default("usd") @db.VarChar(3)
  status                String   @default("pending") // "pending", "completed", "failed"
  donorName             String?
  donorMessage          String?  @db.VarChar(500)
  anonymous             Boolean  @default(false)
  createdAt             DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

